platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end

post_integrate do |installer|
  project = Xcodeproj::Project.open(File.join(__dir__, 'Runner.xcodeproj'))
  target = project.targets.find { |t| t.name == 'Runner' }
  if target
    existing = target.shell_script_build_phases.find { |phase| phase.name == 'Copy Rust Framework' }
    existing&.remove_from_project
    phase = target.new_shell_script_build_phase('Copy Rust Framework')
    phase.shell_script = <<-SCRIPT
      FRAMEWORK_NAME="cardmind_rust.framework"
      FRAMEWORK_BINARY="cardmind_rust"
      ROOT_DIR="${PROJECT_DIR}/.."
      if [[ "$SDK_NAME" == *"simulator"* ]]; then
        RUST_TARGET="aarch64-apple-ios-sim"
        SOURCE_DYLIB="${ROOT_DIR}/rust/target/aarch64-apple-ios-sim/release/libcardmind_rust.dylib"
      else
        RUST_TARGET="aarch64-apple-ios"
        SOURCE_DYLIB="${ROOT_DIR}/rust/target/aarch64-apple-ios/release/libcardmind_rust.dylib"
      fi
      DEST_FRAMEWORK="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/${FRAMEWORK_NAME}"
      DEST_BINARY="${DEST_FRAMEWORK}/${FRAMEWORK_BINARY}"
      DEST_INFO_PLIST="${DEST_FRAMEWORK}/Info.plist"

      (
        cd "${ROOT_DIR}/rust" &&
        cargo build --release --target "$RUST_TARGET"
      ) || exit 1

      if [ -f "$SOURCE_DYLIB" ]; then
        mkdir -p "$DEST_FRAMEWORK"
        cp "$SOURCE_DYLIB" "$DEST_BINARY"
        cat > "$DEST_INFO_PLIST" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>cardmind_rust</string>
  <key>CFBundleIdentifier</key>
  <string>com.example.cardmind.cardmind-rust</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>cardmind_rust</string>
  <key>CFBundlePackageType</key>
  <string>FMWK</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
</dict>
</plist>
EOF
        echo "Copied Rust framework binary to app bundle"
      else
        echo "Warning: Rust dylib not found at $SOURCE_DYLIB"
      fi
    SCRIPT
    project.save
  end
end
